    "tmux",
    "pty",
    "sdk"
  ],
  "license": "MIT",
  "author": "xluos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xluos/agents-remote-sdk.git"
  },
  "homepage": "https://github.com/xluos/agents-remote-sdk#readme",
  "devDependencies": {
    "typescript": "^5.6.0",
